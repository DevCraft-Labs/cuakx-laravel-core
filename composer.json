{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "cuakx/cuakx-core",
    "description": "Core utilities, base classes, and helpers for Cuakx Laravel microservices.",
    "type": "library",
    "license": "MIT",
    "keywords": ["laravel", "cuakx", "core", "utilities"],
    "authors": [
        {
            "name": "Cuakx",
            "homepage": "https://github.com/CuaMcCarsaree44"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/http": "^11.0|^12.0|^13.0",
        "illuminate/routing": "^11.0|^12.0|^13.0",
        "illuminate/redis": "^11.0|^12.0|^13.0",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "illuminate/validation": "^11.0|^12.0|^13.0",
        "symfony/console": "^7.0",
        "ramsey/uuid": "^4.7"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "orchestra/testbench": "^9.0"
    },
    "autoload": {
        "psr-4": {
            "Cuakx\\Core\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Cuakx\\Core\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    },
    "minimum-stability": "stable"
}
